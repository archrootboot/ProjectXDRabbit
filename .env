#OPTIONS(ADMIN)
APP_PACKAGE=com.view.ytrabbit
APP_MAIN_ACTIVITY=com.view.ytrabbit.MainActivity
NEW_COMMAND_TIMEOUT = 1000
WEBDRIVER_URL=http://127.0.0.1:4723


#OPTIONS(USER)

#
#WATCH_TIME_VALUES=60      → duration == 60
#WATCH_TIME_VALUES=60,90   → duration in 60,90
#WATCH_TIME_VALUES=<60     → duration < 60
#WATCH_TIME_VALUES=>60     → duration > 60
#WATCH_TIME_VALUES=<=60    → duration <= 60
#WATCH_TIME_VALUES=>=60    → duration >= 60
#WATCH_TIME_VALUES=        → all videos
WATCH_TIME_VALUES = >=120


#Max watch other skip count - default 10 if not set
MAX_SKIPS=10

#Max point not updated error count - default 10 if not set
MAX_POINT_ERRORS=10       ← number of errors
#Max point not updated error time window in seconds - default 1800 if not set
MAX_POINT_ERROR_TIME=1800 